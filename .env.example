# URL de l'API locale compatible OpenAI (vLLM, Ollama, LM Studio, LocalAI)
# Exemples standards :
# - LM Studio / vLLM / LocalAI : http://127.0.0.1:8000/v1/chat/completions ou http://localhost:1234/v1/chat/completions
# - Ollama (via compatibilité OpenAI v1) : http://localhost:11434/v1/chat/completions
LOCAL_AI_URL=http://127.0.0.1:8000/v1/chat/completions

# Nom du modèle configuré localement à appeler
# Exemples : phi-4, llama3, mlx-community/phi-4-4bit, etc.
LOCAL_AI_MODEL=mlx-community/phi-4-4bit

# Temps d'attente maximum en secondes avant abandon et fallback automatique sur Gemini Cloud
LOCAL_AI_TIMEOUT=60

# Clé API locale (optionnelle, laisser vide si non requise)
LOCAL_AI_API_KEY=
